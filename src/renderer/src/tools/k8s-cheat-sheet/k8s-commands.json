[
  {
    "id": "basic",
    "label": "基础操作",
    "icon": "☸️",
    "commands": [
      {
        "command": "kubectl get pods",
        "description": "查看所有 Pod",
        "example": "kubectl get pods -A"
      },
      {
        "command": "kubectl get svc",
        "description": "查看所有 Service",
        "example": "kubectl get svc -A"
      },
      {
        "command": "kubectl get nodes",
        "description": "查看所有节点",
        "example": "kubectl get nodes -o wide"
      },
      {
        "command": "kubectl get deployments",
        "description": "查看所有 Deployment",
        "example": "kubectl get deployments -A"
      },
      {
        "command": "kubectl get all",
        "description": "查看所有资源",
        "example": "kubectl get all -n default"
      },
      {
        "command": "kubectl cluster-info",
        "description": "查看集群信息",
        "example": "kubectl cluster-info"
      },
      {
        "command": "kubectl version",
        "description": "查看 kubectl 版本",
        "example": "kubectl version --client"
      },
      {
        "command": "kubectl api-resources",
        "description": "查看支持的资源类型",
        "example": "kubectl api-resources --namespaced=true"
      }
    ]
  },
  {
    "id": "debug",
    "label": "调试 & 日志",
    "icon": "🔍",
    "commands": [
      {
        "command": "kubectl describe <resource> <name>",
        "description": "查看资源详情（事件、状态）",
        "example": "kubectl describe pod my-pod"
      },
      {
        "command": "kubectl logs <pod>",
        "description": "查看 Pod 日志",
        "example": "kubectl logs my-pod --tail=100"
      },
      {
        "command": "kubectl logs -f <pod>",
        "description": "实时跟踪日志",
        "example": "kubectl logs -f my-pod -c my-container"
      },
      {
        "command": "kubectl exec -it <pod> -- <cmd>",
        "description": "在 Pod 中执行命令",
        "example": "kubectl exec -it my-pod -- /bin/sh"
      },
      {
        "command": "kubectl port-forward <pod> <local>:<remote>",
        "description": "端口转发",
        "example": "kubectl port-forward svc/my-svc 8080:80"
      },
      {
        "command": "kubectl top pods",
        "description": "查看 Pod 资源使用",
        "example": "kubectl top pods -A --sort-by=memory"
      },
      {
        "command": "kubectl top nodes",
        "description": "查看节点资源使用",
        "example": "kubectl top nodes"
      },
      {
        "command": "kubectl get events",
        "description": "查看集群事件",
        "example": "kubectl get events --sort-by='.lastTimestamp'"
      }
    ]
  },
  {
    "id": "deploy",
    "label": "部署 & 更新",
    "icon": "🚀",
    "commands": [
      {
        "command": "kubectl apply -f <file>",
        "description": "应用配置文件",
        "example": "kubectl apply -f deployment.yaml"
      },
      {
        "command": "kubectl create deployment <name> --image=<img>",
        "description": "快速创建 Deployment",
        "example": "kubectl create deployment nginx --image=nginx:latest"
      },
      {
        "command": "kubectl expose deployment <name> --port=<p>",
        "description": "暴露 Deployment 为 Service",
        "example": "kubectl expose deployment nginx --port=80 --type=LoadBalancer"
      },
      {
        "command": "kubectl set image deployment/<name> <c>=<img>",
        "description": "更新镜像",
        "example": "kubectl set image deployment/nginx nginx=nginx:1.25"
      },
      {
        "command": "kubectl rollout status deployment/<name>",
        "description": "查看滚动更新状态",
        "example": "kubectl rollout status deployment/nginx"
      },
      {
        "command": "kubectl rollout undo deployment/<name>",
        "description": "回滚到上一版本",
        "example": "kubectl rollout undo deployment/nginx"
      },
      {
        "command": "kubectl rollout history deployment/<name>",
        "description": "查看更新历史",
        "example": "kubectl rollout history deployment/nginx"
      },
      {
        "command": "kubectl scale deployment/<name> --replicas=<N>",
        "description": "水平扩展",
        "example": "kubectl scale deployment/nginx --replicas=5"
      }
    ]
  },
  {
    "id": "manage",
    "label": "资源管理",
    "icon": "📋",
    "commands": [
      {
        "command": "kubectl delete <resource> <name>",
        "description": "删除资源",
        "example": "kubectl delete pod my-pod"
      },
      {
        "command": "kubectl delete -f <file>",
        "description": "按配置文件删除",
        "example": "kubectl delete -f deployment.yaml"
      },
      {
        "command": "kubectl label <resource> <name> <key>=<val>",
        "description": "添加标签",
        "example": "kubectl label pod my-pod env=prod"
      },
      {
        "command": "kubectl annotate <resource> <name> <key>=<val>",
        "description": "添加注解",
        "example": "kubectl annotate pod my-pod note='test'"
      },
      {
        "command": "kubectl taint nodes <node> <key>=<val>:<effect>",
        "description": "设置节点污点",
        "example": "kubectl taint nodes node1 dedicated=gpu:NoSchedule"
      },
      {
        "command": "kubectl cordon <node>",
        "description": "标记节点不可调度",
        "example": "kubectl cordon node1"
      },
      {
        "command": "kubectl drain <node>",
        "description": "排空节点（维护前）",
        "example": "kubectl drain node1 --ignore-daemonsets"
      },
      {
        "command": "kubectl uncordon <node>",
        "description": "恢复节点调度",
        "example": "kubectl uncordon node1"
      }
    ]
  },
  {
    "id": "config",
    "label": "配置 & 上下文",
    "icon": "⚙️",
    "commands": [
      {
        "command": "kubectl config get-contexts",
        "description": "查看所有集群上下文",
        "example": "kubectl config get-contexts"
      },
      {
        "command": "kubectl config use-context <ctx>",
        "description": "切换集群上下文",
        "example": "kubectl config use-context production"
      },
      {
        "command": "kubectl config current-context",
        "description": "查看当前上下文",
        "example": "kubectl config current-context"
      },
      {
        "command": "kubectl config set-context --current --namespace=<ns>",
        "description": "设置默认命名空间",
        "example": "kubectl config set-context --current --namespace=production"
      },
      {
        "command": "kubectl get namespaces",
        "description": "查看所有命名空间",
        "example": "kubectl get namespaces"
      },
      {
        "command": "kubectl create namespace <ns>",
        "description": "创建命名空间",
        "example": "kubectl create namespace staging"
      },
      {
        "command": "kubectl config view",
        "description": "查看完整 kubeconfig",
        "example": "kubectl config view --minify"
      },
      {
        "command": "kubectl config set-credentials <user> --token=<token>",
        "description": "设置用户凭据",
        "example": "kubectl config set-credentials admin --token=xxx"
      }
    ]
  },
  {
    "id": "troubleshoot",
    "label": "故障排查",
    "icon": "🛠️",
    "commands": [
      {
        "command": "kubectl get pods --field-selector=status.phase!=Running",
        "description": "查找非 Running 的 Pod",
        "example": "kubectl get pods -A --field-selector=status.phase!=Running"
      },
      {
        "command": "kubectl get pods --sort-by='.status.startTime'",
        "description": "按启动时间排序",
        "example": "kubectl get pods --sort-by='.status.startTime'"
      },
      {
        "command": "kubectl debug node/<node> -it --image=<img>",
        "description": "调试节点（临时 Pod）",
        "example": "kubectl debug node/node1 -it --image=busybox"
      },
      {
        "command": "kubectl auth can-i <verb> <resource>",
        "description": "检查权限",
        "example": "kubectl auth can-i create pods"
      },
      {
        "command": "kubectl get ingress",
        "description": "查看 Ingress 规则",
        "example": "kubectl get ingress -A"
      },
      {
        "command": "kubectl get pvc",
        "description": "查看持久化存储卷",
        "example": "kubectl get pvc -A"
      },
      {
        "command": "kubectl get secrets",
        "description": "查看 Secret",
        "example": "kubectl get secrets -A"
      },
      {
        "command": "kubectl get configmap",
        "description": "查看 ConfigMap",
        "example": "kubectl get configmap -A"
      }
    ]
  }
]
